# 本地开发用：复制为 .env 后修改
DATABASE_URL="mysql://app:app123456@localhost:3306/server_asset?charset=utf8mb4"
ENCRYPTION_KEY=your-secret-key-at-least-16-chars

# 登录验证（部署必填）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
JWT_SECRET=your-jwt-secret-at-least-32-chars

# 每日费用查询通知（仅当费用变动>$50且>50%，或查询失败时发送）
# Gmail：需在 Google 账号开启两步验证，并生成「应用专用密码」https://myaccount.google.com/apppasswords
NOTIFY_EMAIL_TO=your@gmail.com
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=465
NOTIFY_SMTP_USER=your@gmail.com
NOTIFY_SMTP_PASS=你的应用专用密码

# Webhook（可选，钉钉/企微等）
# NOTIFY_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# NOTIFY_WEBHOOK_TYPE=dingtalk
