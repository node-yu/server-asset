# MySQL 配置（与 docker-compose 中的变量对应）
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=server_asset
MYSQL_USER=app
MYSQL_PASSWORD=app123456

# 密码加密密钥（必须配置，至少 16 字符，用于加密存储服务器密码）
ENCRYPTION_KEY=K9mP2xR7vL4nQ8wJ3bF6hT1cY5zA0sD

# 登录验证（部署必填）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
JWT_SECRET=nugti2nhKFGUJeaC2fYbW4iCPF6XE8NF

# 生产环境 CORS（可选，不填则允许任意来源；填则逗号分隔，如 https://your-domain.com,https://www.your-domain.com）
CORS_ORIGIN=https://cloudxbasec.com/

# ========== 域名管理 API（可选，仅在使用域名同步功能时配置） ==========
# Porkbun: PORKBUN_API_KEY=  PORKBUN_SECRET_KEY=
# Namecheap: NAMECHEAP_API_USER=  NAMECHEAP_API_KEY=  NAMECHEAP_USERNAME=  NAMECHEAP_CLIENT_IP=
# Namecheap 请求间隔（毫秒，默认 3500，约 17 次/分钟，避免触发 Too many requests）
# NAMECHEAP_API_DELAY_MS=3500
# GoDaddy: GODADDY_API_KEY=  GODADDY_API_SECRET=
# GoDaddy 测试环境: GODADDY_API_BASE=https://api.ote-godaddy.com
